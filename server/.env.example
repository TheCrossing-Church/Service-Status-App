NODE_ENV=development
PORT=3000

# SQLite database file. Local dev defaults to ./tmp/dev.db; the prod
# compose stack mounts a volume at /data and points here.
DATABASE_PATH=./tmp/dev.db

# JWT auth — generate with `openssl rand -base64 48`
JWT_SECRET=change-me-in-production
# jsonwebtoken format: "12h", "7d", or seconds as a number
JWT_EXPIRES_IN=12h

# CORS (comma-separated). Leave blank to allow same-origin only.
CORS_ORIGINS=http://localhost:5173

# VAPID keys for web push — generate with `npm run vapid:generate`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:it@thecrossing.church

# Rock RMS — leave blank to use local-password auth fallback (dev)
ROCK_BASE_URL=
ROCK_API_KEY=

# Optional: override the bootstrap admin password the seed script sets
SEED_ADMIN_PASSWORD=
