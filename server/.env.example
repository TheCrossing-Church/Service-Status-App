NODE_ENV=development
PORT=4000

# Postgres connection — matches docker-compose.yml defaults
DATABASE_URL=postgres://postgres:postgres@localhost:5432/service_progress
# Used by docker compose to provision the postgres container; in `prod`
# profile the app builds DATABASE_URL from these too.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=service_progress

# Session
SESSION_SECRET=change-me-in-production
SESSION_MAX_AGE_MS=43200000

# CORS (comma-separated). Leave blank to allow same-origin only.
CORS_ORIGINS=http://localhost:5173

# VAPID keys for web push — generate with `npm run vapid:generate`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:it@thecrossing.church

# Rock RMS — leave blank to use local-password auth fallback (dev)
ROCK_BASE_URL=
ROCK_API_KEY=

# Reverse proxy (only used by the `prod` compose profile)
DOMAIN=localhost
CADDY_EMAIL=it@thecrossing.church

# Optional: override the bootstrap admin password the seed script sets
SEED_ADMIN_PASSWORD=
