{
  "name": "service-progress-update-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend for the Crossing Service Progress Update Tool",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "vapid:generate": "tsx scripts/generate-vapid.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.12.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "@types/web-push": "^3.6.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
